# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sunsense

# ── JWT ──
SECRET_KEY=change-me-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── ESP32 Device Key (shared secret the device sends in headers) ──
ESP32_API_KEY=change-me-device-secret
DEFAULT_DEVICE_ID=device-001

# ── Firebase Realtime Database ──
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.region.firebasedatabase.app
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccountKey.json
